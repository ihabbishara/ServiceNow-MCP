{
  "name": "sre-ops-monorepo",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": "^20.19 || >=22.12"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "vitest run",
    "setup": "npm install && npm run build",
    "start": "node packages/sre-agent/dist/cli/index.js",
    "init": "node packages/sre-agent/dist/cli/index.js init",
    "doctor": "node packages/sre-agent/dist/cli/index.js doctor",
    "dev:agent": "npm run dev --workspace @sre/sre-agent",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.7.5",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "prettier": "^3.9.4",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^2.1.2"
  }
}
