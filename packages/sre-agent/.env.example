# @sre/sre-agent — example environment.
# Copy to `.env` (or export these) before running. All values below are
# PLACEHOLDERS — never commit real secrets. `.env.example` is committed;
# `.env` must stay untracked.
#
# Read by `loadAgentConfig` (packages/sre-agent/src/config.ts) and by core's
# `loadConfig` (packages/core/src/config.ts) via `createMcpRuntime`.

# ── ServiceNow (required) ────────────────────────────────────────────────────
SERVICENOW_BASE_URL=https://acme.service-now.com   # instance base URL
SERVICENOW_USERNAME=svc-sre                          # ServiceNow username
SERVICENOW_PASSWORD=change-me                        # ServiceNow password (SECRET)
SERVICENOW_PROXY=                                    # optional http(s) proxy for ServiceNow calls

# ── Azure DevOps auth mode ───────────────────────────────────────────────────
ADO_AUTH_MODE=azcli                                  # azcli (no-PAT, via `az login`) or pat
AZ_PATH=az                                           # path to the Azure CLI binary
ADO_ORG_URL=https://dev.azure.com/INGCDaaS           # required in azcli mode
ADO_PROJECT=IngOne                                   # required in azcli mode
ADO_PROXY=                                           # optional http(s) proxy for ADO PAT-mode calls

# ── Azure DevOps PAT mode (only when ADO_AUTH_MODE=pat) ──────────────────────
ADO_ENABLED=false                                    # core PAT path; true requires ORG_URL+PROJECT+PAT
# ADO_PAT=                                           # personal access token (SECRET; pat mode only — uncomment to use)

# ── Azure DevOps work-item defaults ──────────────────────────────────────────
ADO_AREA_PATH=                                       # default area path for created bugs (default: ADO_PROJECT)
ADO_ITERATION_PATH=                                  # default iteration path (default: ADO_PROJECT)
ADO_ASSIGNED_TEAM=                                   # default assigned team for created bugs
ADO_CREATE_BUG_ENABLED=true                          # feature flag for the create-bug write tool

# ── LLM mode (seat default = GitHub Copilot; BYOK fallback) ──────────────────
LLM_MODE=seat                                        # seat (Copilot seat auth) or byok
LLM_MODEL=gpt-5                                       # model id (or your BYOK deployment/model)
# Seat auth (LLM_MODE=seat) — both OPTIONAL. Leave unset to let the SDK use the
# credential the `copilot` CLI logged into. Set ONE if every chat turn 403s with
# "Authorization error, you may need to run /login":
#   • COPILOT_GITHUB_TOKEN — explicit token handed to the SDK (highest priority;
#     bypasses env-token auto-detect, so a stray GH_TOKEN/GITHUB_TOKEN in your
#     shell can't poison the connection). Use a gho_/ghu_/github_pat_ token
#     (e.g. `gh auth token`), NOT a classic ghp_ PAT.
#   • COPILOT_HOME — point the SDK's bundled runtime at the SAME credential store
#     the `copilot` CLI uses (default ~/.copilot). Set only if your CLI stores its
#     login elsewhere. The in-tool `/login` (device flow) writes here too.
# COPILOT_GITHUB_TOKEN=                               # SECRET; seat mode only
# COPILOT_HOME=                                       # e.g. C:\Users\you\.copilot
COPILOT_IGNORE_ENV_TOKEN=true                         # default true: strip ambient
#   GH_TOKEN/GITHUB_TOKEN/COPILOT_GITHUB_TOKEN from the Copilot runtime's env so it
#   uses your `copilot login` OAuth. An ambient (non-Copilot) token there is the
#   usual cause of "Authorization error … /login". Set false to opt back in.
# BYOK only — uncomment + fill ALL THREE when LLM_MODE=byok (leave commented for seat/Copilot):
# LLM_PROVIDER=azure                                  # azure | anthropic | openai
# LLM_BASE_URL=https://<resource>.openai.azure.com   # provider endpoint URL
# LLM_API_KEY=change-me                               # provider API key (SECRET; optional for local providers)
AZURE_API_VERSION=2024-10-21                          # Azure OpenAI api-version (provider.type=azure only)

# ── Behavior ─────────────────────────────────────────────────────────────────
CONFIRM_WRITES=true                                  # prompt y/N before the create-bug write tool

# ── Stale-ticket thresholds (minutes; passed through to core) ────────────────
STALE_P1_MIN=30                                       # P1 stale threshold
STALE_P2_MIN=120                                      # P2 stale threshold
STALE_P3_MIN=1440                                     # P3 stale threshold
STALE_P4_MIN=4320                                     # P4 stale threshold

# ── Change-correlation window (hours; passed through to core) ─────────────────
CORRELATION_HOURS_BEFORE=24                           # search window before an incident
CORRELATION_HOURS_AFTER=4                             # search window after an incident

# ── Knowledge crawler (internal docs → semantic index) ───────────────────────
# Embeddings run locally in-process (transformers.js / ONNX) — NO Ollama, works
# in both seat and BYOK chat modes. The crawl relevance "verdict" reuses your
# LLM_* config: BYOK → the provider's chat API; seat → heuristic crawl (index
# everything in-scope, no per-page LLM call).
# Setting CRAWL_SEEDS also STEERS THE CHAT toward the index: it appends a
# system-prompt nudge (seat + BYOK) and the workflows call search_knowledge.
KNOWLEDGE_DB_PATH=                                   # default ~/.sre-agent/knowledge.db
CRAWL_SEEDS=                                         # comma list of seed URLs; required for `crawl`; also enables chat RAG steering
CRAWL_ALLOW_DOMAINS=                                 # comma list of hosts; default = hosts of seeds
CRAWL_MAX_PAGES=200
CRAWL_MAX_DEPTH=3
CRAWL_CONCURRENCY=4                                  # reserved (crawl is sequential in v1)
CRAWL_RATE_MS=500
CRAWL_MAX_BYTES=2097152
CRAWL_PROXY=                                         # optional http(s) proxy for crawl + verdict traffic
CRAWL_RESPECT_ROBOTS=true
CRAWL_TOPIC=                                         # optional relevance anchor (BYOK verdict only)
EMBED_MODEL=Xenova/bge-small-en-v1.5                 # local embedding model id (dim pinned in the index)
EMBED_MODEL_PATH=                                    # optional: local model dir for fully offline use (no HF download)
